---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nanobot local admin" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        --bg: #f3efe4;
        --panel: rgba(255, 252, 247, 0.84);
        --panel-strong: #fffaf1;
        --line: rgba(36, 30, 19, 0.12);
        --text: #1f1a11;
        --muted: #655a49;
        --accent: #0e7c66;
        --accent-soft: rgba(14, 124, 102, 0.12);
        --warn: #9c5c16;
        --danger: #9d2a2a;
        --shadow: 0 24px 60px rgba(72, 49, 17, 0.12);
        font-family: "IBM Plex Sans", "Avenir Next", "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(14, 124, 102, 0.18), transparent 28%),
          radial-gradient(circle at top right, rgba(229, 165, 40, 0.2), transparent 26%),
          linear-gradient(180deg, #f7f1e3 0%, var(--bg) 100%);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      main {
        width: min(1240px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 32px 0 56px;
      }

      .hero {
        display: grid;
        gap: 14px;
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: linear-gradient(160deg, rgba(255, 250, 241, 0.96), rgba(248, 242, 230, 0.86));
        box-shadow: var(--shadow);
      }

      .eyebrow {
        font-size: 0.82rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      h1, h2, h3 {
        margin: 0;
        font-family: "Avenir Next Condensed", "Arial Narrow", sans-serif;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      h1 {
        font-size: clamp(2.4rem, 5vw, 4.6rem);
        line-height: 0.94;
      }

      h2 {
        font-size: 1.5rem;
      }

      p {
        margin: 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .stack {
        display: grid;
        gap: 18px;
        margin-top: 24px;
      }

      .grid {
        display: grid;
        gap: 18px;
      }

      .grid.cards {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .panel {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(18px);
        border-radius: 24px;
        padding: 20px;
        box-shadow: var(--shadow);
      }

      .panel.strong {
        background: var(--panel-strong);
      }

      .metric {
        display: grid;
        gap: 8px;
      }

      .metric-value {
        font-size: 2rem;
        font-weight: 700;
      }

      .bot-list {
        display: grid;
        gap: 14px;
      }

      .bot-card {
        display: grid;
        gap: 12px;
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 16px;
        background: rgba(255, 250, 242, 0.78);
      }

      .bot-top,
      .row,
      .actions {
        display: flex;
        gap: 10px;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.82rem;
        background: rgba(31, 26, 17, 0.06);
      }

      .badge.running {
        background: var(--accent-soft);
        color: var(--accent);
      }

      .badge.stopped,
      .badge.missing {
        background: rgba(157, 42, 42, 0.1);
        color: var(--danger);
      }

      .badge.unknown,
      .badge.created {
        background: rgba(156, 92, 22, 0.1);
        color: var(--warn);
      }

      button,
      input {
        font: inherit;
      }

      button {
        border: 0;
        border-radius: 14px;
        padding: 10px 14px;
        background: var(--text);
        color: #fffaf1;
        cursor: pointer;
      }

      button.secondary {
        background: rgba(31, 26, 17, 0.08);
        color: var(--text);
      }

      button:disabled {
        opacity: 0.6;
        cursor: wait;
      }

      form {
        display: grid;
        gap: 12px;
      }

      .form-grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .shell-grid {
        display: grid;
        gap: 18px;
        grid-template-columns: minmax(0, 1.75fr) minmax(320px, 0.95fr);
        align-items: start;
      }

      .chat-shell {
        display: grid;
        gap: 12px;
      }

      .chat-log {
        min-height: 260px;
        max-height: 420px;
        overflow: auto;
        display: grid;
        gap: 10px;
      }

      .chat-bubble {
        padding: 12px 14px;
        border-radius: 16px;
        background: rgba(31, 26, 17, 0.06);
      }

      .chat-bubble.user {
        background: rgba(14, 124, 102, 0.1);
      }

      .chat-bubble.assistant {
        background: rgba(229, 165, 40, 0.12);
      }

      .composer {
        display: grid;
        gap: 10px;
      }

      .composer textarea {
        width: 100%;
        min-height: 120px;
        resize: vertical;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px;
        background: rgba(255, 255, 255, 0.92);
        font: inherit;
      }

      .mount-shell {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 252, 247, 0.7);
        overflow: hidden;
      }

      .bot-ui-host {
        width: 100%;
        min-height: 720px;
        background: #fff;
      }

      .bot-ui-host[data-loading="true"] {
        opacity: 0.72;
      }

      input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 12px 14px;
        background: rgba(255, 255, 255, 0.9);
      }

      .terminal {
        border-radius: 18px;
        background: #191611;
        color: #e7dbc1;
        padding: 16px;
        overflow: auto;
        min-height: 240px;
        font-family: "SFMono-Regular", "Menlo", monospace;
        font-size: 0.9rem;
        line-height: 1.5;
        white-space: pre-wrap;
      }

      .muted {
        color: var(--muted);
      }

      .small {
        font-size: 0.88rem;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }

      .empty {
        padding: 24px;
        border-radius: 18px;
        border: 1px dashed var(--line);
        color: var(--muted);
        text-align: center;
      }

      @media (max-width: 720px) {
        main {
          width: min(100vw - 20px, 1240px);
          padding-top: 20px;
        }

        .shell-grid {
          grid-template-columns: 1fr;
        }

        .hero,
        .panel {
          padding: 18px;
          border-radius: 22px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
  </html>
