FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

# Local fork overlay: keep upstream Dockerfile untouched and add Faster-Whisper support here.
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates gnupg git ffmpeg openssh-client && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get purge -y gnupg && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
RUN mkdir -p nanobot bridge && touch nanobot/__init__.py && \
    uv pip install --system --no-cache . && \
    rm -rf nanobot bridge

COPY nanobot/ nanobot/
COPY bridge/ bridge/
COPY website/ website/
RUN uv pip install --system --no-cache . && \
    uv pip install --system --no-cache faster-whisper

RUN git config --global --add url."https://github.com/".insteadOf ssh://git@github.com/ && \
    git config --global --add url."https://github.com/".insteadOf git@github.com:

WORKDIR /app/bridge
RUN npm install && npm run build
WORKDIR /app/website
RUN npm install && npm run build && cp -R dist /app/admin-ui
WORKDIR /app

RUN mkdir -p /root/.nanobot

EXPOSE 18790

ENTRYPOINT ["nanobot"]
CMD ["status"]
